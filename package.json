{
  "name": "blog",
  "version": "1.0.0",
  "description": "Creating this blog site to put to use the tech stack that I've learnt in my internship",
  "main": "index.ts",
  "type": "module",
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-react",
      "@babel/preset-typescript"
    ]
  },
  "scripts": {
    "client install": "npm install --prefix client",
    "build": "tsc",
    "start": "node index.ts",
    "server": "nodemon index.ts",
    "client": "npm start --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "heroku-postbuild": "NPM_CONFIG_PRODUCTION=false npm install --prefix client && npm run build --prefix client"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bailey-j/blog.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bailey-j/blog/issues"
  },
  "homepage": "https://github.com/bailey-j/blog#readme",
  "dependencies": {
    "@types/cors": "^2.8.8",
    "axios": "^0.21.0",
    "concurrently": "^5.3.0",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "moment": "^2.29.1",
    "mongoose": "^5.10.15",
    "react": "^17.0.1",
    "react-dom": "^17.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.12.3",
    "@babel/preset-env": "^7.12.1",
    "@babel/preset-react": "^7.12.5",
    "@babel/preset-typescript": "^7.12.1",
    "@types/express": "^4.17.9",
    "@types/express-fileupload": "^1.1.5",
    "@types/mongoose": "^5.10.1",
    "@types/multer": "^1.4.4",
    "@types/node": "^14.14.8",
    "@types/react": "^16.9.56",
    "@types/react-dom": "^16.9.9",
    "express-fileupload": "^1.2.0",
    "multer": "^1.4.2",
    "nodemon": "^2.0.6",
    "ts-node-dev": "^1.0.0",
    "typescript": "^4.0.5"
  }
}
