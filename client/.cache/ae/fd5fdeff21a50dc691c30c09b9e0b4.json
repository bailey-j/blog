   {posts\n              .sort(\n                (a, b) =>\n                  new Date(a.date).getTime() - new Date(b.date).getTime()\n              )\n              .reverse()\n              .map((post, key) => (\n                <BlogCard key={key} post={post} />\n              ))}\n          </ul>\n        </div>\n      </div>\n    </>\n  );\n}\n"},"lineCount":null}},"error":null,"hash":"bb51c55d5b60a1deb699f30930c7916a","cacheData":{"env":{}}}